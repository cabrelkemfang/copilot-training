# --- Build outputs (Maven/Java) ---
target/
!**/src/main/**/target/
!**/src/test/**/target/
build/
!**/src/main/**/build/
!**/src/test/**/build/
out/
*.class

# --- Packaged artifacts ---
*.jar
*.war
*.ear
*.nar

# --- Logs / runtime files ---
logs/
*.log
spring.log
hs_err_pid*
replay_pid*

# --- Maven wrapper ---
# Keep these tracked for reproducible builds:
!mvnw
!mvnw.cmd
!.mvn/wrapper/maven-wrapper.properties
# Ignore wrapper JAR (downloaded/generated as needed)
.mvn/wrapper/maven-wrapper.jar

# --- Spring local environment ---
.env
.env.*
*.local

# --- STS / Eclipse ---
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# --- IntelliJ IDEA ---
.idea/
*.iws
*.iml
*.ipr

# --- NetBeans ---
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# --- VS Code ---
.vscode/

# --- OS files ---
.DS_Store
Thumbs.db

